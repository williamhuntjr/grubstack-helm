pipeline {
    agent any
    parameters {
        string(name: 'ACTION', defaultValue: 'deploy', description: 'deploy or remove')
        string(name: 'SLUG', description: 'Customer slug')
        string(name: 'TENANT_ID', description: 'Tenant UUID')
        string(name: 'API_URL', description: 'Customer API URL')
        string(name: 'SITE_URL', description: 'Customer site URL')
        string(name: 'PRODUCTION_URL', defaultValue: 'https://grubstack.app', description: 'GrubStack production URL')
        string(name: 'CDN_URL', defaultValue: 'https://cdn.grubstack.app', description: 'CDN URL')
    }
    stages {
        stage('Deploy') {
            when {
                expression { params.ACTION == 'deploy' }
            }
            steps {
                sh """
                    helm upgrade --install grubstack-core-${params.SLUG} /opt/grubstack-helm/grubstack-core \\
                        --set customer.host=core-${params.SLUG}.grubstack.app \\
                        --set customer.tenantId=${params.TENANT_ID} \\
                        --set customer.apiUrl=${params.API_URL} \\
                        --set customer.productionUrl=${params.PRODUCTION_URL} \\
                        --set customer.siteUrl=${params.SITE_URL} \\
                        --set customer.cdnUrl=${params.CDN_URL} \\
                        --namespace grubstack
                """
            }
        }
        stage('Remove') {
            when {
                expression { params.ACTION == 'remove' }
            }
            steps {
                sh "helm uninstall grubstack-core-${params.SLUG} --namespace grubstack"
            }
        }
    }
}
